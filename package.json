{
  "devDependencies": {
    "@svgr/core": "^6.2.1",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/node": "^18.0.4",
    "@types/react": "^17.0.2",
    "react-native-builder-bob": "^0.18.3",
    "typescript": "^4.7.4",
    "@types/bun": "latest"
  },
  "name": "@epic-group/heroicons",
  "version": "0.0.1",
  "main": "lib/commonjs/index.js",
  "react-native": "src/index.tsx",
  "module": "lib/module/index.js",
  "types": "index.d.ts",
  "scripts": {
    "prepare": "bun generate && bunx bob build",
    "generate": "bun ./generate/index.ts"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "dependencies": {
    "baseline-browser-mapping": "^2.10.40",
    "caniuse-lite": "^1.0.30001799",
    "react-native-svg": "^13.1.0"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "private": false
}
